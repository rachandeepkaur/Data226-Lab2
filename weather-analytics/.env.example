# Copy to .env and fill in (never commit .env or paste secrets into chat).
# Account is your Snowflake account locator, e.g. xy12345.us-east-1 or orgname-accountname

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=ANALYTICS
# If unset, load_snowflake_connection.sh uses SNOWFLAKE_USER as role (avoid PUBLIC on USER_DB_*).
# SNOWFLAKE_ROLE=
# SNOWFLAKE_REGION=
